# ── Backend (FastAPI / Render) ─────────────────────────────────────────────
# Required. Get a free key at https://console.groq.com/keys
# Local non-Docker dev: copy this value into backend/.env
# Docker Compose: copy this file to .env at the repo root
# Render: set GROQ_API_KEY in the dashboard (do NOT commit it)
GROQ_API_KEY=your_groq_api_key_here

# ── Frontend (Next.js / Vercel) ────────────────────────────────────────────
# Production only. The browser calls the deployed Render backend directly.
# Leave UNSET for local dev — the Next.js dev server proxies /api/* to the
# backend at BACKEND_URL (default http://localhost:8000).
# NEXT_PUBLIC_API_URL=https://algolens-backend.onrender.com

# Optional: override the local dev proxy target (defaults to localhost:8000).
# BACKEND_URL=http://localhost:8000
